# Copy these keys into your backend host environment dashboard.
# Never commit the real .env file.

NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/bluemantle

# Auth
# Use at least 64 random characters. Example generation: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_plus_character_secret

# Frontend origin for CORS and secure cookies
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Zoom Server-to-Server OAuth
ZOOM_ACCOUNT_ID=replace_with_zoom_account_id
ZOOM_CLIENT_ID=replace_with_zoom_client_id
ZOOM_CLIENT_SECRET=replace_with_zoom_client_secret

# Zoom Meeting SDK for embedded classroom
SDK_ID=replace_with_zoom_meeting_sdk_id
SDK_SECRET=replace_with_zoom_meeting_sdk_secret

# YouTube integration
YOUTUBE_API_KEY=replace_with_youtube_api_key
YOUTUBE_CHANNEL_ID=replace_with_youtube_channel_id

# Optional: use only if hosting DNS needs a custom resolver
DNS_SERVERS=1.1.1.1,8.8.8.8
